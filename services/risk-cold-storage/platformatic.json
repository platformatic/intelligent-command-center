{
  "$schema": "https://schemas.platformatic.dev/@platformatic/db/3.54.0.json",
  "db": {
    "connectionString": "{PLT_COLD_STORAGE_DATABASE_URL}",
    "graphql": false,
    "openapi": true
  },
  "watch": {
    "enabled": "{DEV_K8S}",
    "ignore": [
      "*.sqlite",
      "*.sqlite-journal"
    ]
  },
  "migrations": {
    "dir": "migrations",
    "autoApply": true
  },
  "plugins": {
    "paths": [
      "./plugins",
      "./routes"
    ]
  },
  "types": {
    "autogenerate": false
  }
}
