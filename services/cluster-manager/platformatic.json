{
  "$schema": "https://schemas.platformatic.dev/@platformatic/db/3.54.0.json",
  "server": {
    "logger": {
      "level": "info"
    },
    "maxParamLength": 1000,
    "pluginTimeout": 60000
  },
  "db": {
    "connectionString": "{PLT_CLUSTER_MANAGER_DATABASE_URL}",
    "openapi": true,
    "schemalock": true
  },
  "migrations": {
    "dir": "migrations",
    "autoApply": true
  },
  "plugins": {
    "paths": [
      "./plugins",
      "./routes"
    ]
  },
  "watch": "{DEV_K8S}"
}
