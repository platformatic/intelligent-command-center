{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "verbatimModuleSyntax": true,
    "noImplicitAny": false,
    "preserveConstEnums": true,
    "skipLibCheck": true,
    "strict": false,
    "allowJs": true,
    "checkJs": false
  },
  "include": ["lib/**/*", "plugins/**/*", "routes/**/*", "test/**/*"]
}
