{
  "$schema": "https://schemas.platformatic.dev/@platformatic/db/3.54.0.json",
  "watch": {
    "enabled": "{DEV_K8S}"
  },
  "db": {
    "connectionString": "{PLT_SCALER_DATABASE_URL}",
    "graphql": true,
    "openapi": {
      "ignoreRoutes": [
        {
          "method": "POST",
          "path": "/controllers"
        },
        {
          "method": "POST",
          "path": "/alerts"
        },
        {
          "method": "POST",
          "path": "/flamegraphs"
        },
        {
          "method": "GET",
          "path": "/flamegraphs"
        },
        {
          "method": "POST",
          "path": "/signals"
        }
      ]
    },
    "limit": {
      "default": 100,
      "max": 1000
    }
  },
  "migrations": {
    "dir": "migrations",
    "autoApply": true
  },
  "plugins": {
    "paths": [
      "./plugins",
      "./routes"
    ]
  }
}
