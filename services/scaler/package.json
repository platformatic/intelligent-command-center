{
  "version": "3.8.0",
  "scripts": {
    "start": "platformatic start",
    "test": "npm run lint && DOTENV_CONFIG_QUIET=true borp --concurrency 1 --timeout=60000 --ignore 'test/pattern-predictor/*.test.js' --ignore 'test/pattern-predictor/complex/**' --ignore 'test/pattern-predictor/schedule/**'",
    "test:coverage": "npm run lint && DOTENV_CONFIG_QUIET=true borp --concurrency 1 --timeout=60000 --ignore 'test/pattern-predictor/*.test.js' --ignore 'test/pattern-predictor/complex/**' --ignore 'test/pattern-predictor/schedule/**' --coverage",
    "test:patterns": "npm run test:patterns:unit && npm run test:patterns:complex && npm run test:patterns:schedule",
    "test:patterns:unit": "node --test test/pattern-predictor/*.test.js",
    "test:patterns:complex": "node test/pattern-predictor/complex/runner.mjs",
    "test:patterns:schedule": "node test/pattern-predictor/schedule/runner.mjs",
    "simulate": "node simulations/server.js",
    "lint": "standard ."
  },
  "devDependencies": {
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.1.0",
    "borp": "^1.0.0",
    "fastify": "^5.4.0",
    "pg": "^8.16.3",
    "platformatic": "^3.54.0",
    "snazzy": "^9.0.0",
    "standard": "^17.1.2"
  },
  "dependencies": {
    "@databases/pg": "^5.5.0",
    "@fastify/deepmerge": "^3.2.0",
    "@fastify/env": "^5.0.1",
    "@fastify/error": "^4.1.0",
    "@platformatic/db": "^3.54.0",
    "fastify-plugin": "^5.0.1",
    "iovalkey": "^0.3.1",
    "luxon": "^3.7.2",
    "mqemitter-redis": "^7.1.0",
    "rrule": "^2.8.1",
    "undici": "^7.8.0",
    "massimo": "^1.2.0"
  }
}
