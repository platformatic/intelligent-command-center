{
  "$schema": "https://schemas.platformatic.dev/@platformatic/db/3.54.0.json",
  "server": {
    "pluginTimeout": 60000
  },
  "db": {
    "connectionString": "{PLT_CONTROL_PLANE_DATABASE_URL}",
    "graphql": true,
    "openapi": true,
    "events": false,
    "schemalock": true,
    "limit": {
      "default": 100,
      "max": 1000
    }
  },
  "migrations": {
    "dir": "migrations",
    "autoApply": true
  },
  "types": {
    "autogenerate": true
  },
  "plugins": {
    "paths": [
      "./plugins",
      "./routes"
    ]
  },
  "watch": "{DEV_K8S}"
}
